{
  "schemaVersion": 1,
  "protocolVersion": "1.0.0",
  "module": {
    "id": "ggsel.seller",
    "version": "1.2.0",
    "displayName": "GGSel Seller",
    "description": "Передаёт покупки и сообщения GGSel в сценарии Buywell и отправляет ответы покупателям.",
    "publisher": "Buywell",
    "supportedPlatforms": [
      "GGSel"
    ],
    "documentation": {
      "homepageUrl": "https://github.com/moreveal/buywell-runtimes/tree/main/ggsel",
      "sourceUrl": "https://github.com/moreveal/buywell-runtimes"
    }
  },
  "package": {
    "branding": {
      "icon": "assets/ggsel-square-icon.png"
    },
    "artifact": {
      "path": "runtime/ggsel-seller-runtime-1.2.0.zip",
      "filename": "ggsel-seller-runtime-1.2.0.zip"
    },
    "guides": {
      "installation": {
        "ru": "guides/install.ru.md",
        "en": "guides/install.en.md"
      },
      "readme": {
        "ru": "guides/README.ru.md",
        "en": "guides/README.en.md"
      },
      "changelog": {
        "ru": "guides/CHANGELOG.ru.md",
        "en": "guides/CHANGELOG.en.md"
      }
    },
    "compatibility": {
      "environments": [
        "Windows 10/11 with Python 3.11+",
        "Linux with Python 3.11+"
      ]
    },
    "release": {
      "critical": false
    }
  },
  "events": [
    {
