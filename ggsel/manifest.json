  "nodes": [
    {
      "type": "ggsel.seller/send-message",
      "version": "1.0.0",
      "kind": "action",
      "displayName": "Send message",
      "description": "Sends a message to the GGSel chat associated with the current event.",
      "localization": {
        "ru": {
          "displayName": "Отправить сообщение",
          "description": "Отправляет сообщение в чат GGSel, из которого запущен сценарий."
        },
        "en": {
          "displayName": "Send message",
          "description": "Sends a message to the GGSel chat that started the workflow."
        }
