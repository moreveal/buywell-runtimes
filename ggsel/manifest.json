        "ru": {
          "displayName": "Получена покупка",
          "description": "Запускается, когда runtime находит новую оплаченную покупку GGSel."
        },
        "en": {
          "displayName": "Purchase received",
          "description": "Starts when the runtime finds a new paid GGSel purchase."
        }
      },
      "payloadSchema": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "paidAt": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "amountRub": {
            "type": "number"
          },
          "amountUsd": {
            "type": "number"
